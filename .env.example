# Copy to .env and fill in. .env is gitignored.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: for OpenAI-compatible swap path (provider=openai in settings.yaml)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Data sources (added per phase; leave blank to disable that source) ---
FRED_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=                    # FinancialModelingPrep — auto earnings-call transcripts
TAVILY_API_KEY=
GMAIL_ADDRESS=                  # newsletter inbox for `pead research` (IMAP enabled)
GMAIL_APP_PASSWORD=             # 2FA required: https://myaccount.google.com/apppasswords
GMAIL_PROXY=                    # optional, e.g. socks5://127.0.0.1:7897 (default: proxy env vars)
SEC_EDGAR_USER_AGENT=ats-bot you@example.com
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ats-bot/0.1

# --- IBKR (paper) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497            # 7497 = TWS paper, 4002 = IB Gateway paper
IBKR_CLIENT_ID=11
IBKR_ACCOUNT=

# --- Boss approval channels ---
# App mode (full interactive callbacks):
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=                 # chat that receives approval cards (chat_id)
FEISHU_VERIFICATION_TOKEN=      # event-subscription verification token (recommended)
FEISHU_BASE_URL=https://open.feishu.cn   # open.larksuite.com for Lark
# Group custom-bot mode (one-way push + URL-button approval; simpler, no app):
FEISHU_BOT_WEBHOOK=             # https://open.feishu.cn/open-apis/bot/v2/hook/<id>
FEISHU_BOT_SECRET=             # only if the bot enables 签名校验
FEISHU_APPROVE_BASE=           # public base URL of `ats serve` (e.g. ngrok), for buttons
FEISHU_APPROVE_SECRET=         # any random string; HMAC-protects the approve links
DISCORD_BOT_TOKEN=
