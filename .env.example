# Copy to .env and fill in. .env is gitignored.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: for OpenAI-compatible swap path (provider=openai in settings.yaml)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Data sources (added per phase; leave blank to disable that source) ---
FRED_API_KEY=
FINNHUB_API_KEY=
TAVILY_API_KEY=
SEC_EDGAR_USER_AGENT=ats-bot you@example.com
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ats-bot/0.1

# --- IBKR (paper) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497            # 7497 = TWS paper, 4002 = IB Gateway paper
IBKR_CLIENT_ID=11
IBKR_ACCOUNT=

# --- Boss approval channels ---
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=                 # chat that receives approval cards (chat_id)
FEISHU_VERIFICATION_TOKEN=      # event-subscription verification token (recommended)
FEISHU_BASE_URL=https://open.feishu.cn   # open.larksuite.com for Lark
DISCORD_BOT_TOKEN=
